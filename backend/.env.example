SPRING_PROFILES_ACTIVE=dev

# PostgreSQL (Supabase or local)
# Prefer Session pooler on Render (IPv4). Direct db.<REF>.supabase.co is IPv6-only.
DB_URL=jdbc:postgresql://aws-0-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.<PROJECT_REF>
DB_PASSWORD=change-me

# CORS — comma-separated origins (defaults already include localhost + *.vercel.app)
# Production example: https://service-scheduler-puce.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT (HMAC secret must be at least 32 characters)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Initial admin (created on first boot if missing; blocked in prod if left as defaults)
ADMIN_EMAIL=admin@agendapro.local
ADMIN_PASSWORD=Admin@12345

# Rate limiting (in-memory, per IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_APPOINTMENT_PER_MINUTE=30
RATE_LIMIT_DEFAULT_PER_MINUTE=120

APP_TIMEZONE=America/Sao_Paulo
SPRINGDOC_ENABLED=true
